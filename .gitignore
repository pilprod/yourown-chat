# Terraform / OpenTofu
**/.terraform/*
# Ignore transient per-module lock files, but KEEP each stack root lock file:
# HCP Terraform Stacks requires .terraform.lock.hcl committed at each stack root.
**/.terraform.lock.hcl
!/stacks/*/.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# Secrets / local vars (commit *.example templates instead)
*.tfvars
*.tfvars.json
!*.tfvars.example
!*.tfvars.json.example
*-credentials.json
*.key.json
service-account*.json

# OS / editor
.DS_Store
*.swp
